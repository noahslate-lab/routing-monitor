# Routing Monitor Configuration

# Chili Piper API
CHILI_PIPER_API_KEY=your_chili_piper_api_key_here
CHILI_PIPER_BASE_URL=https://fire.chilipiper.com/api/fire-edge

# HubSpot (optional — enables ownership sync checks, flip-flop detection, meeting verification)
HUBSPOT_API_KEY=your_hubspot_api_key_here
HUBSPOT_BASE_URL=https://api.hubapi.com
HUBSPOT_PORTAL_ID=21261434

# Slack Bot (create a separate Slack app for this — not the Deal Desk Bot)
SLACK_BOT_TOKEN=xoxb-your-routing-monitor-bot-token
SLACK_ROUTING_MONITOR_CHANNEL=routing-monitor

# Polling interval (minutes)
ROUTING_MONITOR_INTERVAL_MINUTES=10

# Application
ENVIRONMENT=development
PORT=8100
